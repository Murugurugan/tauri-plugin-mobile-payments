{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext", // <-- Add this (or "ES2020")
    "strict": false,
    "moduleResolution": "node",
    "allowJs": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "declaration": true,
    "declarationDir": "../webview-dist",
    "outDir": "../webview-dist", // Rollup's output.dir takes precedence for final JS
    "rootDir": ".",
    "preserveConstEnums": true // <-- Add this
  },
  "include": ["./index.ts", "./bindings.ts"],
  "exclude": ["node_modules", "../webview-dist"]
}